{
  "name": "reddb-cli",
  "version": "0.2.7",
  "description": "CLI launcher for RedDB. The JS/TS app driver is published as package `reddb`.",
  "type": "commonjs",
  "bin": {
    "reddb-cli": "./drivers/js/src/cli.js"
  },
  "files": [
    "drivers/js/src/",
    "drivers/js/postinstall.js",
    "drivers/js/package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "node drivers/js/postinstall.js",
    "test": "node drivers/js/test/smoke.test.mjs",
    "version": "node scripts/sync-version.js"
  },
  "keywords": [
    "database",
    "multi-model",
    "vector-search",
    "graph",
    "document-store",
    "key-value",
    "rust",
    "embedded"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forattini-dev/reddb"
  },
  "homepage": "https://github.com/forattini-dev/reddb"
}
