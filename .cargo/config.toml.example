# Cargo build configuration template.
#
# Copy to `.cargo/config.toml` to activate the local linker speedup.
# `mold` works well with Rust incremental builds. `sccache` is useful
# too, but it conflicts with incremental compilation, so it stays
# optional and commented out below.
#
# Prerequisites:
#   sudo apt install mold clang sccache   # or: sudo dnf install mold clang sccache
#
# After installing, run:
#   cp .cargo/config.toml.example .cargo/config.toml
#
# `.cargo/config.toml` is gitignored (or should be — add it if
# missing) so each developer keeps their own build config.

# ---------------------------------------------------------------------
# Linker — mold via clang driver
# ---------------------------------------------------------------------
#
# mold is a parallel single-pass linker that links the reddb binary
# in ~1s instead of ~5s with GNU ld. Big win on incremental dev
# builds where the linker dominates the rebuild cost.

[target.x86_64-unknown-linux-gnu]
linker = "clang"
rustflags = [
    "-C", "link-arg=-fuse-ld=mold",
    # Optional: shrink dwarf debug info for faster link time.
    # Enable if your IDE/debugger doesn't need full type info.
    # "-C", "link-arg=-Wl,--compress-debug-sections=zlib",
]

[target.aarch64-unknown-linux-gnu]
linker = "clang"
rustflags = ["-C", "link-arg=-fuse-ld=mold"]

# ---------------------------------------------------------------------
# Optional compiler cache — sccache
# ---------------------------------------------------------------------
#
# sccache hashes the source + flags and caches the .rlib output
# under ~/.cache/sccache. On a fresh checkout or a branch switch
# that touches a few files, the cache hits ~80% of the deps and
# the build collapses from minutes to seconds.
#
# Important:
# Rust incremental compilation and sccache are mutually exclusive.
# For normal local dev this repo prefers incremental builds. Enable
# the wrapper only for CI or for one-off local builds where you also
# run with `CARGO_INCREMENTAL=0`.

# [build]
# rustc-wrapper = "sccache"
# Optional: cap parallelism if your machine OOMs on heavy crates.
# jobs = 8
